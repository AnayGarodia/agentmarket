[Unit]
Description=Aztea Elixir OTP service (job lifecycle + PubSub)
After=network.target postgresql.service aztea.service
Requires=postgresql.service

[Service]
Type=simple
User=aztea
Group=aztea
WorkingDirectory=/home/aztea/elixir-release

# Load the same .env as the Python server so DATABASE_URL, ELIXIR_HTTP_PORT
# (defaults to 4000) and ELIXIR_INTERNAL_SHARED_SECRET are available. The
# secret is shared with Python so one rotated value updates both directions
# of the realtime bridge.
EnvironmentFile=/home/aztea/app/.env
# Bind the realtime endpoint to loopback only. nginx/Caddy upgrades the
# /elixir/socket path; nothing else should reach the sidecar.
Environment=ELIXIR_HTTP_PORT=4000

ExecStart=/home/aztea/elixir-release/bin/aztea start
ExecStop=/home/aztea/elixir-release/bin/aztea stop

Restart=on-failure
RestartSec=5s

# OTP 25 on Ubuntu 24.04 ERTS segfaults on SIGTERM; send SIGINT instead which
# triggers a clean :init.stop/0 path and avoids the SEGV crash dump on shutdown.
KillSignal=SIGINT
# Give the VM up to 30 s to flush Postgres connections and flush PubSub state.
TimeoutStopSec=30

# OTP crash dumps land here; readable without sudo.
Environment=ERL_CRASH_DUMP=/home/aztea/elixir-release/erl_crash.dump

StandardOutput=journal
StandardError=journal
SyslogIdentifier=aztea-elixir

[Install]
WantedBy=multi-user.target
